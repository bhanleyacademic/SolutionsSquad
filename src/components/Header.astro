---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === `${base}/`) return currentPath === href || currentPath === base;
  return currentPath.startsWith(href);
}
---
<header class="site-header header-style-6 dark mo-left">
  <div class="sticky-header main-bar-wraper navbar-expand-lg">
    <div class="main-bar clearfix">

      <!-- Top bar -->
      <div class="top-bar">
        <div class="container top-bar-crve">
          <div class="row justify-content-between">
            <div class="dez-topbar-left">
              <ul class="social-line text-center pull-right">
                <!--<li><a href="mailto:solutionssquad@example.com"><i class="fa fa-envelope-o"></i> <span>solutionssquad@example.com</span></a></li>-->
                <li><a href="#"><i class="fa fa-map-marker"></i> <span>Bloomington, IN</span></a></li>
              </ul>
            </div>
            <div class="dez-topbar-right">
              <ul class="social-line text-center pull-right">
                <li><a href="#" class="fa fa-facebook"></a></li>
                <li><a href="#" class="fa fa-instagram"></a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Header bar -->
      <div class="header-bar">
        <div class="container clearfix">
          <!-- Logo -->
          <div class="logo-header mostion">
            <a href={`${base}/`}>
              <span style="font-family:'Oswald',sans-serif; font-size:28px; font-weight:700; color:#fff; letter-spacing:2px; line-height:1.2;">
                SOLUTIONS<br><span style="color:#35B494;">SQUAD</span>
