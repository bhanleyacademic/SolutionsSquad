---
import { games } from '../data/schedule';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getFullYear();
const nextGame = games.find(g => g.result === null);
---
<footer class="site-footer footer-overlay bg-img-fix footer-skew"
  style={`background-image:url(${base}/images/background/bg5.jpg); background-position:center bottom; background-size:cover;`}>
  <div class="footer-top">
    <div class="container">
      <div class="row">

        <!-- About column -->
        <div class="col-xl-4 col-lg-4 col-md-6 col-sm-6">
          <div class="widget widget_about">
            <h4 class="footer-title" style="font-family:'Oswald',sans-serif; letter-spacing:2px; color:#fff;">
              SOLUTIONS<span class="text-primary"> SQUAD</span>
            </h4>
            <p>A casual co-ed softball team bringing competitive spirit and good times to the Bloomington recreational league. Come out and cheer us on!</p>
            <!--<ul class="social-list mt-4">
              <li><a href="#" class="site-button facebook circle"><i class="fa fa-facebook"></i></a></li>
              <li><a href="#" class="site-button instagram circle"><i class="fa fa-instagram"></i></a></li>
            </ul>-->
          </div>
        </div>

        <!-- Quick links -->
        <div class="col-xl-2 col-lg-2 col-md-6 col-sm-6">
          <div class="widget widget_services border-0">
            <h5 class="footer-title">Quick Links</h5>
            <ul>
              <li><a href={`${base}/`}>Home</a></li>
              <!--<li><a href={`${base}/roster`}>Roster</a></li>-->
              <li><a href={`${base}/schedule`}>Schedule</a></li>
              <li><a href={`${base}/gallery`}>Gallery</a></li>
              <!--<li><a href={`${base}/about`}>About</a></li>-->
            </ul>
          </div>
        </div>

        <!-- Contact -->
        <!--<div class="col-xl-3 col-lg-3 col-md-6 col-sm-6">
          <div class="widget widget_getintuch">
            <h5 class="footer-title">Contact Us</h5>
            <ul>
              <li>
                <i class="ti-location-pin"></i>
                <strong>Location</strong>
                <span>Bloomington, IN</span>
              </li>
              <li>
                <i class="ti-email"></i>
                <strong>Email</strong>
                <span>solutionssquad@example.com</span>
              </li>
            </ul>
          </div>
        </div>-->

        <!-- Next game (live from schedule data) -->
        <div class="col-xl-3 col-lg-3 col-md-6 col-sm-6">
          <div class="widget">
            <h5 class="footer-title">Next Game</h5>
            {nextGame ? (
              <div class="p-3" style="background:rgba(112,224,0,0.08); border-left:4px solid var(--primary,#70e000); border-radius:4px;">
                <p class="m-0" style="color:#fff; line-height:1.8;">
                  <strong class="text-primary">{nextGame.date}</strong><br>
                  vs. {nextGame.opponent}<br>
                  <i class="fa fa-map-marker text-primary"></i> {nextGame.field} · {nextGame.time}
                </p>
              </div>
            ) : (
              <p style="color:#888; font-size:14px;">Season complete — see you next year!</p>
            )}
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <div class="row">
        <div class="col-md-6 col-sm-6 text-left">
          <span>© {year} Solutions Squad Softball. All rights reserved.</span>
        </div>
        <div class="col-md-6 col-sm-6 text-right">
          <span>Built with <a href="https://astro.build" class="text-primary">Astro</a> &amp; SportsZone template</span>
        </div>
      </div>
    </div>
  </div>
</footer>
