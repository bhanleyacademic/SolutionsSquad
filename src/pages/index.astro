---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { players } from '../data/players';
import { games } from '../data/schedule';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nextGame = games.find(g => g.result === null);
const recentResults = games.filter(g => g.result !== null).slice(-2).reverse();
const featuredPlayers = players.slice(0, 4);
---
<BaseLayout title="Home">
  <Header slot="header" />

  <!-- Hero Banner -->
  <div class="dez-bnr-inr overlay-black-dark"
    style={`background-image:url(${base}/images/photos/IMG_0170.JPG); background-size:cover; background-position:center 40%; min-height:520px; display:flex; align-items:center;`}>
    <div class="container" style="padding:120px 15px 80px;">
      <div class="row align-items-center">
        <div class="col-lg-7">
          <span class="text-primary" style="font-family:'Oswald',sans-serif; font-size:20px; font-weight:500; letter-spacing:3px; text-transform:uppercase;">
            Bloomington Recreational Softball
          </span>
          <h1 style="font-family:'Oswald',sans-serif; font-size:64px; line-height:1.1; color:#fff; font-weight:700; margin:12px 0 20px;">
            SOLUTIONS<br><span class="text-primary">SQUAD</span>
          </h1>
          <p style="color:#ccc; font-size:16px; max-width:520px; margin-bottom:30px;">
            Where casual fun meets competitive heart. We play, we laugh, we win — occasionally in that order.
          </p>
          <a href={`${base}/schedule`} class="site-button m-r15">See Schedule</a>
          <a href={`${base}/roster`} class="site-button button-outline-1">Meet the Squad</a>
        </div>
        {nextGame && (
          <div class="col-lg-5 d-none d-lg-block">
            <div class="p-4" style="background:rgba(0,0,0,0.6); border:2px solid #35B494; border-radius:8px;">
              <p class="text-primary m-0" style="font-family:'Oswald',sans-serif; font-size:13px; letter-spacing:2px; text-transform:uppercase;">Next Game</p>
              <h3 style="color:#fff; font-family:'Oswald',sans-serif; margin:8px 0 4px;">vs. {nextGame.opponent}</h3>
              <p style="color:#aaa; margin:0;">
                <i class="fa fa-calendar text-primary"></i> {nextGame.date}<br>
                <i class="fa fa-clock-o text-primary"></i> {nextGame.time}<br>
                <i class="fa fa-map-marker text-primary"></i> {nextGame.field} · Bloomington, IN
              </p>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Recent Results -->
  {recentResults.length > 0 && (
    <div class="section-full bg-black content-inner-2">
      <div class="container">
        <div class="section-head text-center text-white">
          <h2 class="title" style="font-family:'Oswald',sans-serif;">Recent Results</h2>
          <div class="dez-separator-outer"><div class="dez-separator bg-primary style-skew"></div></div>
        </div>
        <div class="row justify-content-center mt-4">
          {recentResults.map(game => (
            <div class="col-lg-5 col-md-6 mb-4">
              <div class="p-4 text-center" style={`background:#1a1a1a; border-top:4px solid ${game.result === 'W' ? 'var(--primary,#70e000)' : '#e74c3c'}; border-radius:4px;`}>
                <span class="badge" style={`background:${game.result === 'W' ? 'var(--primary,#70e000)' : '#e74c3c'}; color:${game.result === 'W' ? '#000' : '#fff'}; font-size:14px; padding:6px 16px; letter-spacing:1px;`}>
                  {game.result === 'W' ? 'WIN' : 'LOSS'}
                </span>
                <h4 style="color:#fff; font-family:'Oswald',sans-serif; margin:12px 0 4px;">vs. {game.opponent}</h4>
                <p class="text-primary" style="font-size:28px; font-weight:700; font-family:'Oswald',sans-serif; margin:0;">{game.ssScore}–{game.oppScore}</p>
                <p style="color:#888; margin:4px 0 0; font-size:13px;">{game.date} · {game.field}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="text-center mt-2">
          <a href={`${base}/schedule`} class="site-button">Full Schedule & Results</a>
        </div>
      </div>
    </div>
  )}

