---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { players } from '../data/players';

const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Roster" description="Meet the Solutions Squad softball roster — our players, positions, and numbers.">
  <Header slot="header" />

  <!-- Page banner -->
  <div class="dez-bnr-inr overlay-black-middle"
    style={`background-image:url(${base}/images/background/bg4.jpg); background-size:cover; background-position:center;`}>
    <div class="container">
      <div class="dez-bnr-inr-entry">
        <h1 class="text-white" style="font-family:'Oswald',sans-serif;">Team Roster</h1>
      </div>
    </div>
  </div>
  <div class="breadcrumb-row">
    <div class="container">
      <ul class="list-inline">
        <li><a href={`${base}/`}>Home</a></li>
        <li>Roster</li>
      </ul>
    </div>
  </div>

  <!-- Roster grid -->
  <div class="section-full content-inner bg-gray-dark">
    <div class="container">
      <div class="section-head text-center text-white">
        <h2 class="title" style="font-family:'Oswald',sans-serif;">2026 Season Roster</h2>
        <div class="dez-separator-outer"><div class="dez-separator bg-primary style-skew"></div></div>
        <p style="color:#aaa; margin-top:12px;">The crew taking the field for Solutions Squad this season.</p>
      </div>

      <div class="row mt-4">
        {players.map(player => (
          <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 mb-4">
            <div class="dez-box dez-team2">
              <div class="dez-media dez-img-overlay2 dez-img-effect zoom" style="position:relative;">
                <img src={player.photo} alt={player.name} style="width:100%; height:300px; object-fit:cover;">
                <div class="overlay-bx">
                  <div class="overlay-icon">
                    <span style="background:var(--primary,#70e000); color:#000; padding:8px 20px; border-radius:4px; font-size:15px; font-family:'Oswald',sans-serif; font-weight:700;">
                      #{player.number}
                    </span>
                  </div>
                </div>
                <!-- Jersey number badge -->
                <div style="position:absolute; top:12px; left:12px; background:var(--primary,#70e000); color:#000; width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Oswald',sans-serif; font-weight:700; font-size:14px;">
                  {player.number}
                </div>
              </div>
              <div class="dez-info p-a20 border-1" style="background:#1a1a1a; border-top:3px solid var(--primary,#70e000);">
                <h5 class="dez-title m-t0 m-b5">
                  <a href="#" style="color:#fff; font-family:'Oswald',sans-serif;">{player.name}</a>
                </h5>
                <p class="text-primary m-b8" style="font-size:12px; letter-spacing:1.5px; text-transform:uppercase; font-weight:600;">{player.position}</p>
                <p style="color:#999; font-size:13px; line-height:1.6; margin:0;">{player.bio}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
