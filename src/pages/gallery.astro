---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Photos from /images/photos/ — full-size used for both thumb and lightbox
// Selected for variety: golden-hour action, batting, fielding, two game sessions
const p = (f: string) => `${base}/images/photos/${f}`;
const photos = [
  { src: p('IMG_0170.JPG'), caption: 'Dust rising on a golden evening — infield in motion' },
  { src: p('IMG_0255.JPG'), caption: 'Runner rounding first in the golden hour' },
  { src: p('IMG_0340.JPG'), caption: 'Solutions Squad batter mid-follow-through' },
  { src: p('IMG_0320.JPG'), caption: 'Relay throw across the infield' },
  { src: p('IMG_0315.JPG'), caption: 'Racing for second base' },
  { src: p('IMG_0270.JPG'), caption: '#24 watching the play develop' },
  { src: p('IMG_0300.JPG'), caption: 'At the plate — sunset session' },
  { src: p('IMG_0395.JPG'), caption: 'Holding it down in the infield' },
  { src: p('IMG_0285.JPG'), caption: 'Outfield throw, ball in frame' },
  { src: p('IMG_0235.JPG'), caption: 'Tracking it down in center field' },
  { src: p('IMG_0185.JPG'), caption: 'Evening warmup — full squad on the field' },
  { src: p('IMG_0180.JPG'), caption: 'Wide view — team spread across the diamond' },
  { src: p('IMG_0163.JPG'), caption: 'Pitching follow-through, afternoon game' },
  { src: p('IMG_0136.JPG'), caption: 'Batting practice — daytime session' },
  { src: p('IMG_0160.JPG'), caption: 'Crowd in the stands, game day atmosphere' },
  { src: p('IMG_0222.JPG'), caption: 'Walking in ready for game time' },
];
---
<BaseLayout title="Gallery" description="Photo gallery from Solutions Squad softball games and events.">
  <Header slot="header" />

  <!-- Page banner -->
  <div class="dez-bnr-inr overlay-black-middle"
    style={`background-image:url(${base}/images/photos/IMG_0180.JPG); background-size:cover; background-position:center 40%;`}>
    <div class="container">
      <div class="dez-bnr-inr-entry">
        <h1 class="text-white" style="font-family:'Oswald',sans-serif;">Photo Gallery</h1>
      </div>
    </div>
  </div>
  <div class="breadcrumb-row">
    <div class="container">
      <ul class="list-inline">
        <li><a href={`${base}/`}>Home</a></li>
        <li>Gallery</li>
      </ul>
    </div>
  </div>

  <div class="section-full content-inner bg-gray-dark">
    <div class="container">
      <div class="section-head text-center text-white">
        <h2 class="title" style="font-family:'Oswald',sans-serif;">Game Highlights</h2>
        <div class="dez-separator-outer"><div class="dez-separator bg-primary style-skew"></div></div>
        <p style="color:#aaa; margin-top:12px;">Moments from the field, the dugout, and beyond.</p>
      </div>

      <div class="row lightgallery mt-4" id="lightgallery">
        {photos.map(photo => (
          <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 mb-4">
            <a href={photo.src} data-src={photo.src} data-sub-html={`<h4>${photo.caption}</h4>`}
              class="dez-media dez-img-overlay2 dez-img-effect zoom d-block" style="overflow:hidden; border-radius:4px;">
              <img src={photo.src} alt={photo.caption}
                style="width:100%; height:220px; object-fit:cover; display:block;">
              <div class="overlay-bx">
                <div class="overlay-icon">
                  <i class="fa fa-search-plus" style="color:#fff; font-size:24px;"></i>
                </div>
              </div>
            </a>
            <p style="color:#888; font-size:12px; margin-top:6px; text-align:center;">{photo.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<script>
  // Initialize lightGallery if available
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('lightgallery');
    if (el && typeof (window as any).lightGallery === 'function') {
      (window as any).lightGallery(el, { selector: 'a' });
    }
  });
</script>
