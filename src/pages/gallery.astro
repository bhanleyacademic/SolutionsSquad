---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const photos = [
  { src: `${base}/images/gallery/large/img1.jpg`, thumb: `${base}/images/gallery/small/img1.jpg`, caption: 'Game day lineup' },
  { src: `${base}/images/gallery/large/img2.jpg`, thumb: `${base}/images/gallery/small/img2.jpg`, caption: 'Victory celebration' },
  { src: `${base}/images/gallery/large/img3.jpg`, thumb: `${base}/images/gallery/small/img3.jpg`, caption: 'Pitching warmups' },
  { src: `${base}/images/gallery/large/img4.jpg`, thumb: `${base}/images/gallery/small/img4.jpg`, caption: 'Batting practice' },
  { src: `${base}/images/gallery/large/img5.jpg`, thumb: `${base}/images/gallery/small/img5.jpg`, caption: 'Post-game huddle' },
  { src: `${base}/images/gallery/large/img6.jpg`, thumb: `${base}/images/gallery/small/img6.jpg`, caption: 'Team photo 2025' },
  { src: `${base}/images/gallery/large/img7.jpg`, thumb: `${base}/images/gallery/small/img7.jpg`, caption: 'Home run swing' },
  { src: `${base}/images/gallery/large/img8.jpg`, thumb: `${base}/images/gallery/small/img8.jpg`, caption: 'Fielding drills' },
  { src: `${base}/images/gallery/large/img9.jpg`, thumb: `${base}/images/gallery/small/img9.jpg`, caption: 'Dugout vibes' },
  { src: `${base}/images/gallery/large/img10.jpg`, thumb: `${base}/images/gallery/small/img10.jpg`, caption: 'Slide into third' },
  { src: `${base}/images/gallery/large/img11.jpg`, thumb: `${base}/images/gallery/small/img11.jpg`, caption: 'Opening day 2026' },
  { src: `${base}/images/gallery/large/img12.jpg`, thumb: `${base}/images/gallery/small/img12.jpg`, caption: 'Catching in action' },
];
---
<BaseLayout title="Gallery" description="Photo gallery from Solutions Squad softball games and events.">
  <Header slot="header" />

  <!-- Page banner -->
  <div class="dez-bnr-inr overlay-black-middle"
    style={`background-image:url(${base}/images/background/bg5.jpg); background-size:cover; background-position:center;`}>
    <div class="container">
      <div class="dez-bnr-inr-entry">
        <h1 class="text-white" style="font-family:'Oswald',sans-serif;">Photo Gallery</h1>
      </div>
    </div>
  </div>
  <div class="breadcrumb-row">
    <div class="container">
      <ul class="list-inline">
        <li><a href={`${base}/`}>Home</a></li>
        <li>Gallery</li>
      </ul>
    </div>
  </div>

  <div class="section-full content-inner bg-gray-dark">
    <div class="container">
      <div class="section-head text-center text-white">
        <h2 class="title" style="font-family:'Oswald',sans-serif;">Game Highlights</h2>
        <div class="dez-separator-outer"><div class="dez-separator bg-primary style-skew"></div></div>
        <p style="color:#aaa; margin-top:12px;">Moments from the field, the dugout, and beyond.</p>
      </div>

      <div class="row lightgallery mt-4" id="lightgallery">
        {photos.map(photo => (
          <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 mb-4">
            <a href={photo.src} data-src={photo.src} data-sub-html={`<h4>${photo.caption}</h4>`}
              class="dez-media dez-img-overlay2 dez-img-effect zoom d-block" style="overflow:hidden; border-radius:4px;">
              <img src={photo.thumb} alt={photo.caption}
                style="width:100%; height:220px; object-fit:cover; display:block;"
                onerror={`this.src='${base}/images/gallery/large/img1.jpg'`}>
              <div class="overlay-bx">
                <div class="overlay-icon">
                  <i class="fa fa-search-plus" style="color:#fff; font-size:24px;"></i>
                </div>
              </div>
            </a>
            <p style="color:#888; font-size:12px; margin-top:6px; text-align:center;">{photo.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<script>
  // Initialize lightGallery if available
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('lightgallery');
    if (el && typeof (window as any).lightGallery === 'function') {
      (window as any).lightGallery(el, { selector: 'a' });
    }
  });
</script>
